# PaintCRM Server Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Security — BOTH required in production (boot refuses otherwise)
# JWT_SECRET: min 32 chars, no weak defaults
JWT_SECRET=change_this_to_a_random_string_at_least_32_chars
# ALLOWED_ORIGINS: comma-separated public origins (never leave unset in production)
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8080

# Auth token lifetimes
# Short-lived access token (any ms-style duration, e.g. 15m, 1h)
ACCESS_TOKEN_TTL=15m
# Refresh token lifetime in days (rotated on every /api/auth/refresh)
REFRESH_TOKEN_TTL_DAYS=30

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/paintcrm
# Docker:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/paintcrm
# Force TLS on/off explicitly: true|require|false|disable.
# Defaults to on in production. Fly.io internal Postgres => DB_SSL=false.
DB_SSL=
# When SSL is on, set to 'false' only for self-signed certs (e.g. some managed PG)
DB_SSL_REJECT_UNAUTHORIZED=true

# Redis — used for distributed rate limiting when REDIS_URL is set
# Falls back to single-process in-memory limiting when unset (single replica only)
REDIS_URL=redis://localhost:6379

# Monitoring
ENABLE_METRICS=true
# Optional bearer token to protect the /metrics endpoint
METRICS_TOKEN=

# Feature Flags
ENABLE_RATE_LIMITING=true

# AI shade recommender — OpenAI (optional; heuristic fallback when unset or unsigned)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_RECOMMEND_ENABLED=true

# Payment reminders
# WhatsApp: manual send opens wa.me click-to-chat (always available)
# SMS: only when MSG91_AUTH_KEY is set
MSG91_AUTH_KEY=
MSG91_SENDER_ID=PAINTC
# Automated overdue SMS cron — keep false unless MSG91 is configured.
# Cron will NOT send WhatsApp click-to-chat links unattended.
ENABLE_REMINDER_CRON=false
REMINDER_CRON_INTERVAL_MS=86400000
REMINDER_COOLDOWN_DAYS=7
# Optional override; cron ignores whatsapp and requires MSG91 for sms
REMINDER_DEFAULT_CHANNEL=sms

# Optional: serve frontend from a custom directory (defaults to Vite dist/ then source)
# FRONTEND_DIR=

# Docker Compose specific
POSTGRES_PASSWORD=change_this_postgres_password
GRAFANA_ADMIN_PASSWORD=change_this_grafana_password

# Email — password reset (optional; dev logs reset URL to console when unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@paintcrm.example

# Password reset
# Public base URL for reset links (no trailing slash)
APP_PUBLIC_URL=http://localhost:3001
# Reset token lifetime in minutes (default 60)
PASSWORD_RESET_TTL_MINUTES=60
