# PaintCRM Server Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Security
JWT_SECRET=change_this_to_a_random_string_at_least_32_chars
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8080

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/paintcrm
# For Docker:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/paintcrm

# Redis (optional, for rate limiting and sessions)
REDIS_URL=redis://localhost:6379

# Email (for password reset, optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@paintcrm.example

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_RATE_LIMITING=true
